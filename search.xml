<td>rgb(0,0,0)</td>
</tr>
<tr>
<td></td>
<td>#FF0000</td>
<td>rgb(255,0,0)</td>
</tr>
<tr>
<td></td>
<td>#00FF00</td>
<td>rgb(0,255,0)</td>
</tr>
<tr>
<td></td>
<td>#0000FF</td>
<td>rgb(0,0,255)</td>
</tr>
<tr>
<td></td>
<td>#FFFF00</td>
<td>rgb(255,255,0)</td>
</tr>
<tr>
<td></td>
<td>#00FFFF</td>
<td>rgb(0,255,255)</td>
</tr>
<tr>
<td></td>
<td>#FF00FF</td>
<td>rgb(255,0,255)</td>
</tr>
